{
  "name": "template",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "nuxt build && wrangler deploy",
    "typecheck": "nuxt typecheck",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "format": "oxfmt --write",
    "test": "bun test --pass-with-no-tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "setup": "node scripts/setup.mjs",
    "postinstall": "nuxt prepare && simple-git-hooks",
    "prepare": "simple-git-hooks || exit 0"
  },
  "dependencies": {
    "@comark/nuxt": "0.5.1",
    "@nuxt/fonts": "0.14.0",
    "@vueuse/nuxt": "14.3.0",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.22.0",
    "klona": "^2.0.6",
    "nanoid": "^6.0.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "0.5.29",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.111.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,vue}": [
      "bunx oxlint --fix --type-aware",
      "bunx oxfmt --write"
    ],
    "*.{scss,css}": "bunx oxfmt --write"
  },
  "packageManager": "bun@1.3.14"
}
