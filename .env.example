# Seals the session cookie. Must be at least 32 characters. Generate one with: `openssl rand -base64 32`
NUXT_SESSION_PASSWORD=

NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Cloudflare Email Sending. https://developers.cloudflare.com/email-service/
NUXT_EMAIL_FROM_NAME=
NUXT_EMAIL_FROM_ADDRESS=

NUXT_PUBLIC_SITE_URL=
