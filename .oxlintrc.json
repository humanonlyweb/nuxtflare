{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "typescript", "oxc", "vue", "vitest"],
  "jsPlugins": ["./tools/oxlint/architecture.mjs"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-alert": "error",
    "no-console": "warn",
    "no-await-in-loop": "off",
    "unicorn/no-array-sort": "off",
    "no-restricted-globals": "error",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-floating-promises": "error",
    "typescript/consistent-type-imports": "error",
    "arch/no-db-access-in-controllers": "error",
    "arch/no-http-in-services": "error",
    "arch/no-unvalidated-request-reads": "error",
    "arch/no-service-instantiation-outside-container": "error"
  },
  "overrides": [
    {
      "files": ["test/e2e/**/*.ts"],
      "rules": {
        "jest/valid-describe-callback": "off"
      }
    }
  ]
}
